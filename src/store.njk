.badge.solid-dark { background: var(--ink); border-color: var(--ink); color: var(--paper); }
.hero-cta { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
.btn-primary { background: var(--accent-red); color: var(--paper); border: none; padding: 17px 30px; font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 6px 16px rgba(168, 57, 43, 0.25); text-decoration: none; }
