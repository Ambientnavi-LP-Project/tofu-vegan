.hero-video-wrap { position: relative; width: 62%; aspect-ratio: 9/16; max-height: 680px; background: var(--bg-deep); border-radius: 6px; overflow: hidden; box-shadow: 0 30px 60px var(--shadow-deep), 0 8px 20px var(--shadow); z-index: 2; }
.hero-video-wrap video, .hero-video-wrap img.hero-fallback { width: 100%; height: 100%; object-fit: cover; display: block; }
.hero-video-wrap::before { content: ''; position: absolute; inset: 10px; border: 1px solid rgba(250, 245, 233, 0.25); border-radius: 4px; pointer-events: none; z-index: 3; mix-blend-mode: overlay; }
