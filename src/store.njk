.banner-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.5) 100%); display: flex; flex-direction: column; align-items: center; justify-content: flex-end; padding: 60px 24px; color: var(--paper); text-align: center; }
