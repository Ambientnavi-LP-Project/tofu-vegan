<body>

<div class="notice">
  <span><span class="live-dot"></span><strong>Open today</strong></span>
  <span class="sep">·</span>
  <span>{{ store.hours }}</span>
  <span class="sep">·</span>
  <span>Reservation recommended</span>
  <span class="sep">·</span>
  <span>銀座 Ginza</span>
</div>

<header class="header">
  <div class="logo">
    <span class="logo-main">Wagyu &amp; Vegan Hamburger</span>
    <span class="logo-sub">(Halal · Gluten-Free) Tokyo Ginza</span>
    <span class="jp">{{ store.name_jp }}</span>
  </div>
  <div class="header-actions">
    <div class="lang-switch" role="tablist" aria-label="Language">
      <button class="active" type="button" data-lang="EN">EN</button>
      <button type="button" data-lang="JA">日</button>
      <button type="button" data-lang="ZH">中</button>
    </div>
    <a href="{{ store.tablecheck_url }}" target="_blank" rel="noopener" class="btn-reserve" data-ga-event="reserve_click" data-ga-location="header">
      <span class="material-icons">event_seat</span>
      Reserve
    </a>
  </div>
</header>

<section class="hero">
  <div class="hero-calligraphy" aria-hidden="true">豆腐</div>

  <div class="hero-content">
    <span class="hero-eyebrow">for everyone who misses the burger ✦</span>
    <h1>
      Tokyo's <em>growing</em> favorite,<br>
      now <span class="underline">made of tofu.</span>
    </h1>
    <p class="hero-lead">
      A hearty, juicy Japanese-style burger made with premium tofu — the food quietly becoming a global obsession. Hand-crafted in our Ginza kitchen with no compromise on flavor, body, or beauty.
    </p>

    <div class="hero-rating">
      <span class="stars">★★★★★</span>
      <div class="rating-text">
