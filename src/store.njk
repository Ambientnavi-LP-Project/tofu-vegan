.btn-secondary { background: transparent; color: var(--ink); border: 1px solid var(--ink); padding: 16px 24px; font-family: var(--font-body); font-size: 0.85rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: all 0.3s ease; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
.btn-secondary:hover { background: var(--ink); color: var(--paper); }
.hero-urgency { margin-top: 22px; display: flex; flex-direction: column; gap: 6px; font-size: 0.88rem; color: var(--ink-soft); }
