.hero-hanko { position: absolute; top: 22px; right: 22px; width: 84px; height: 84px; background: var(--accent-red); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-family: var(--font-jp); color: var(--paper); font-size: 1.6rem; font-weight: 700; letter-spacing: 0.05em; box-shadow: 0 6px 20px rgba(168, 57, 43, 0.5); writing-mode: vertical-rl; text-orientation: upright; padding: 8px 4px; line-height: 1.1; z-index: 5; animation: hankoSway 6s ease-in-out infinite; }
.scroll-hint { position: absolute; bottom: -28px; right: 18%; display: flex; flex-direction: column; align-items: center; gap: 4px; font-size: 0.62rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--ink-muted); pointer-events: none; animation: scrollHint 2.4s ease-in-out infinite; z-index: 1; }
