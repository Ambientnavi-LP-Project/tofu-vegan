.floating-reserve { background: var(--accent-red); color: var(--paper); border: none; border-radius: 50%; width: 108px; height: 108px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 10px 32px rgba(168, 57, 43, 0.5); font-family: var(--font-body); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; text-decoration: none; line-height: 1.18; transition: all 0.3s ease; text-align: center; padding: 10px; animation: floatPulse 2.4s ease-in-out infinite; }
@keyframes floatPulse { 0%, 100% { box-shadow: 0 10px 32px rgba(168, 57, 43, 0.5); } 50% { box-shadow: 0 10px 40px rgba(168, 57, 43, 0.8), 0 0 0 10px rgba(168, 57, 43, 0.12); } }
