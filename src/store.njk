.story { padding: 120px 48px; background: var(--bg-cream); position: relative; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); overflow: hidden; }
.story::before { content: '銀座'; position: absolute; bottom: -12%; right: -3%; font-family: var(--font-jp); font-size: 26rem; color: var(--accent-deep); opacity: 0.05; font-weight: 700; line-height: 1; pointer-events: none; user-select: none; }
.story-inner { max-width: 880px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
.section-label { font-family: var(--font-body); font-size: 0.75rem; letter-spacing: 0.4em; color: var(--ink-muted); text-transform: uppercase; margin-bottom: 14px; display: inline-block; position: relative; padding: 0 20px; }
.section-label::before, .section-label::after { content: ''; position: absolute; top: 50%; width: 30px; height: 1px; background: var(--line); }
