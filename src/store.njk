.hero-photo-wrap { position: absolute; left: -2%; bottom: 8%; width: 46%; aspect-ratio: 4/5; border-radius: 4px; overflow: hidden; background: var(--bg-deep); box-shadow: 0 24px 50px var(--shadow-deep), 0 6px 16px var(--shadow); border: 6px solid var(--paper); z-index: 3; transform: rotate(-2deg); transition: transform 0.5s ease; }
