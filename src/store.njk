.why-item { text-align: center; }
.why-item .icon-circle { width: 60px; height: 60px; border: 1.5px solid var(--accent-deep); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-family: var(--font-jp); color: var(--accent-deep); font-size: 1.4rem; font-weight: 600; transition: transform 0.4s ease, background 0.4s ease, color 0.4s ease; }
