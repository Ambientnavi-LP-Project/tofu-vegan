.floating-viewers { background: var(--paper); color: var(--ink); border: 1px solid var(--line); border-radius: 100px; padding: 7px 14px 7px 12px; font-family: var(--font-body); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.02em; display: inline-flex; align-items: center; gap: 6px; box-shadow: 0 4px 14px var(--shadow); white-space: nowrap; opacity: 0; transform: translateY(8px); transition: opacity 0.5s ease, transform 0.5s ease; pointer-events: none; }
