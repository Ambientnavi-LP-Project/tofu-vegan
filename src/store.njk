<style>
:root {
  --bg: #f4ede0;
  --bg-cream: #ebe1cc;
  --bg-deep: #e3d5b8;
  --paper: #faf5e9;
  --ink: #2b2419;
  --ink-soft: #5c4f3d;
  --ink-muted: #8a7a62;
  --accent: #6b8e4e;
  --accent-deep: #4a6b35;
  --accent-warm: #c4622d;
  --accent-red: #a8392b;
  --accent-gold: #b8924a;
  --line: #c9b896;
  --shadow: rgba(43, 36, 25, 0.08);
